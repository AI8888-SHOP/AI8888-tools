{
  "name": "ai8888-switch",
  "version": "0.1.1",
  "description": "AI8888 Switch desktop client",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "tauri": "tauri",
    "dev:renderer": "vite --host 127.0.0.1",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit",
    "test:renderer-logic": "node scripts/run-renderer-tests.mjs",
    "build:app": "tauri build --no-bundle",
    "verify:version": "node scripts/verify-version.mjs",
    "test": "npm run test:renderer-logic && cargo test -q --manifest-path src-tauri\\Cargo.toml",
    "check": "npm run typecheck && cargo check -q --manifest-path src-tauri\\Cargo.toml",
    "verify": "npm run verify:version && npm run test && npm run check && npm run build:renderer"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^7.3.0"
  }
}
